# ============================================
# MiniCloud Quick Configuration Template
# ============================================
# Copy this file to .env and customize values

# Database
DB_USER=postgres
DB_PASSWORD=change-this-strong-password
DB_HOST=relational-database-server
DB_PORT=5432

# Keycloak Auth
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-this-strong-password
KEYCLOAK_ISSUER_URL=http://authentication-identity-server:8080/realms/realm_sv001
SMOKE_CLIENT_SECRET=change-this-strong-random-secret

# MinIO Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-strong-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-this-strong-password

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-strong-password

# URLs (update for production)
MINIO_PUBLIC_BASE_URL=http://localhost/storage
API_BASE_URL=http://localhost/api
FRONTEND_URL=http://localhost

# Optional: Keycloak KC_* settings
KC_HOSTNAME=localhost
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true

# See .env.production for complete configuration options and production checklist
